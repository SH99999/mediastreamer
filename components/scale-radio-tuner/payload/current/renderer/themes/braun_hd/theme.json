{
  "_dev_info": {
    "theme_name": "braun_hd",
    "what_this_file_controls": [
      "fonts for scale, UI and mono technical text",
      "layout positions for header, scale, info panel, dimmed logo and VU meter scaffold",
      "colors for ticks, labels, panel and pointer fallback",
      "draw flags to enable or disable generated labels, ticks, logo or VU overlay",
      "layer stack order and pointer sprite behaviour"
    ],
    "asset_files": {
      "background.png": "dark appliance background",
      "backlight.png": "warm backlight behind the scale",
      "scale_bed.png": "recessed scale print bed",
      "glass.png": "glass reflection overlay",
      "vignette.png": "edge darkening",
      "noise.png": "subtle grain",
      "marker.png": "tuning pointer sprite",
      "marker_shadow.png": "pointer shadow sprite"
    },
    "station_notes": [
      "Stations still come from runtime/settings.json as before.",
      "Optional per-station overrides now supported: label_dx, label_dy, marker_dx, marker_dy and label_lines.",
      "Use draw_flags.scale_numbers=false if the numeric print is already baked into scale_bed.png."
    ],
    "logo_notes": [
      "Renderer reads state.albumart and can dim the logo behind the info panel text.",
      "Relative /albumart URLs from Volumio are resolved against http://127.0.0.1:3000."
    ],
    "vu_meter_notes": [
      "This release adds fully configurable VU meter placement and drawing scaffolding.",
      "Audio-driven stereo metering is intentionally split into the next release so renderer stability stays intact."
    ]
  },
  "fonts": {
