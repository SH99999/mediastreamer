{
  "page": {
    "label": "Rotary Encoder II Angle Bridge"
  },
  "sections": [
    {
      "id": "sensor_section",
      "element": "section",
      "label": "Sensor & Wiring",
      "icon": "fa-microchip",
      "onSave": {
        "type": "controller",
        "endpoint": "system_hardware/as5600-angle-tester",
        "method": "saveSensorConfig"
      },
      "saveButton": {
        "label": "Save sensor settings",
        "data": ["enabled", "i2cBus", "i2cAddress", "pollIntervalMs", "startupToast"]
      },
      "content": [
        {"id": "enabled", "element": "switch", "label": "Enable live polling", "value": false},
        {
          "id": "i2cBus",
          "element": "select",
          "label": "I²C bus",
          "value": {"value": 1, "label": "1 (GPIO2/GPIO3)"},
          "options": [
            {"value": 0, "label": "0"},
            {"value": 1, "label": "1 (GPIO2/GPIO3)"},
            {"value": 3, "label": "3"},
            {"value": 4, "label": "4"},
            {"value": 5, "label": "5"},
            {"value": 6, "label": "6"}
          ]
        },
        {"id": "i2cAddress", "element": "input", "type": "text", "label": "I²C address", "value": "0x36"},
        {"id": "pollIntervalMs", "element": "input", "type": "number", "label": "Polling interval (ms)", "value": 50},
        {"id": "startupToast", "element": "switch", "label": "Show startup status toast", "value": true},
        {
          "id": "probeSensor",
          "element": "button",
          "label": "Probe sensor now",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "probeSensor",
              "data": {}
            }
          }
        }
      ]
    },
    {
      "id": "calibration_section",
      "element": "section",
      "label": "Calibration",
      "icon": "fa-compass",
      "onSave": {
        "type": "controller",
        "endpoint": "system_hardware/as5600-angle-tester",
        "method": "saveCalibrationConfig"
      },
      "saveButton": {
        "label": "Save calibration",
        "data": ["invertDirection", "rawMin", "rawMax", "resolutionSteps"]
      },
      "content": [
        {"id": "invertDirection", "element": "switch", "label": "Invert direction", "value": false},
        {"id": "rawMin", "element": "input", "type": "number", "label": "Calibration raw min", "value": 0},
        {"id": "rawMax", "element": "input", "type": "number", "label": "Calibration raw max", "value": 4095},
        {"id": "resolutionSteps", "element": "input", "type": "number", "label": "Action resolution steps", "value": 20},
        {
          "id": "captureMin",
          "element": "button",
          "label": "Capture current angle as min",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "captureMin",
              "data": {}
            }
          }
        },
        {
          "id": "captureMax",
          "element": "button",
          "label": "Capture current angle as max",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "captureMax",
              "data": {}
            }
          }
        },
        {
          "id": "resetCalibration",
          "element": "button",
          "label": "Reset calibration",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "resetCalibration",
              "data": {}
            }
          }
        }
      ]
    },
    {
      "id": "action_section",
      "element": "section",
      "label": "Live angle action",
      "icon": "fa-sliders",
      "onSave": {
        "type": "controller",
        "endpoint": "system_hardware/as5600-angle-tester",
        "method": "saveActionConfig"
      },
      "saveButton": {
        "label": "Save angle action",
        "data": ["actionType", "toastCooldownMs", "volumeStepPercent", "emitEndpoint", "emitMethod", "emitData"]
      },
      "content": [
        {
          "id": "actionType",
          "element": "select",
          "label": "Function while turning",
          "value": {"value": "toast_percent", "label": "Toast current percent"},
          "options": [
            {"value": "none", "label": "Do nothing (monitor only)"},
            {"value": "toast_percent", "label": "Toast current percent"},
            {"value": "volumio_volume", "label": "Map angle to Volumio volume"},
            {"value": "custom_emit", "label": "Call another plugin method"}
          ]
        },
        {"id": "toastCooldownMs", "element": "input", "type": "number", "label": "Toast cooldown (ms)", "value": 350},
        {"id": "volumeStepPercent", "element": "input", "type": "number", "label": "Volume step quantization (%)", "value": 2},
        {"id": "emitEndpoint", "element": "input", "type": "text", "label": "Plugin endpoint", "value": ""},
        {"id": "emitMethod", "element": "input", "type": "text", "label": "Method name", "value": ""},
        {"id": "emitData", "element": "input", "type": "text", "label": "Additional JSON data", "value": "{}"},
        {
          "id": "showCurrentState",
          "element": "button",
          "label": "Show current processed state",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "showCurrentState",
              "data": {}
            }
          }
        }
      ]
    },
    {
      "id": "buttons_section",
      "element": "section",
      "label": "Buttons (Rotary Encoder II style)",
      "icon": "fa-hand-pointer-o",
      "onSave": {
        "type": "controller",
        "endpoint": "system_hardware/as5600-angle-tester",
        "method": "saveButtonConfig"
      },
      "saveButton": {
        "label": "Save button settings",
        "data": ["buttonsEnabled", "buttonActionType", "buttonDebounceMs", "buttonEndpoint", "buttonMethod", "buttonData"]
      },
      "content": [
        {"id": "buttonsEnabled", "element": "switch", "label": "Enable button action layer", "value": false},
        {
          "id": "buttonActionType",
          "element": "select",
          "label": "Button action mode",
          "value": {"value": "transport", "label": "Volumio transport"},
          "options": [
            {"value": "transport", "label": "Volumio transport"},
            {"value": "volume_step", "label": "Volume step"},
            {"value": "custom_emit", "label": "Call another plugin method"}
          ]
        },
        {"id": "buttonDebounceMs", "element": "input", "type": "number", "label": "Button debounce (ms)", "value": 120},
        {"id": "buttonEndpoint", "element": "input", "type": "text", "label": "Custom endpoint", "value": ""},
        {"id": "buttonMethod", "element": "input", "type": "text", "label": "Custom method", "value": ""},
        {"id": "buttonData", "element": "input", "type": "text", "label": "Custom JSON", "value": "{}"},
        {
          "id": "testButtonPrev",
          "element": "button",
          "label": "Test: PREV button",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "simulateButtonPress",
              "data": {"button": "prev"}
            }
          }
        },
        {
          "id": "testButtonSelect",
          "element": "button",
          "label": "Test: SELECT button",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "simulateButtonPress",
              "data": {"button": "select"}
            }
          }
        },
        {
          "id": "testButtonNext",
          "element": "button",
          "label": "Test: NEXT button",
          "onClick": {
            "type": "emit",
            "message": "callMethod",
            "data": {
              "endpoint": "system_hardware/as5600-angle-tester",
              "method": "simulateButtonPress",
              "data": {"button": "next"}
            }
          }
        }
      ]
    }
  ]
}
