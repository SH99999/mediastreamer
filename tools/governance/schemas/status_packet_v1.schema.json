{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SH99999/mediastreamer/tools/governance/schemas/status_packet_v1.schema.json",
  "title": "status_packet_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "component",
    "canonical_status",
    "evidence_links",
    "blockers",
    "recommended_owner_action",
    "next_owner_click",
    "decision_scoring",
    "rollback_action",
    "timestamp",
    "source_commit"
  ],
  "properties": {
    "schema": {
      "const": "status_packet_v1"
    },
    "component": {
      "type": "string",
      "minLength": 1
    },
    "canonical_status": {
      "type": "string",
      "enum": [
        "placeholder",
        "payload_present",
        "deploy_candidate_started",
        "functional_acceptance_pending"
      ]
    },
    "evidence_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_owner_action": {
      "type": "string",
      "enum": [
        "accept",
        "changes-requested",
        "defer",
        "run_workflow"
      ]
    },
    "next_owner_click": {
      "type": "string",
      "enum": [
        "approve_pr",
        "request_changes",
        "run_workflow",
        "defer"
      ]
    },
    "decision_scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_quality",
        "rollback_readiness",
        "blast_radius",
        "confidence"
      ],
      "properties": {
        "evidence_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "rollback_readiness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "blast_radius": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "rollback_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "command",
        "verification"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    }
  }
}
