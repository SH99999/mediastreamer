{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SH99999/mediastreamer/tools/governance/schemas/status_packet_v1.schema.json",
  "title": "status_packet_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "component",
    "canonical_status",
    "evidence_links",
    "blockers",
    "recommended_owner_action",
    "next_owner_click",
    "decision_scoring",
    "rollback_action",
    "claim_classes",
    "component_claims",
    "timestamp",
    "source_commit"
  ],
  "properties": {
    "schema": {
      "const": "status_packet_v1"
    },
    "component": {
      "type": "string",
      "minLength": 1
    },
    "canonical_status": {
      "type": "string",
      "enum": [
        "placeholder",
        "payload_present",
        "deploy_candidate_started",
        "functional_acceptance_pending"
      ]
    },
    "evidence_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_owner_action": {
      "type": "string",
      "enum": [
        "accept",
        "changes-requested",
        "defer",
        "run_workflow"
      ]
    },
    "next_owner_click": {
      "type": "string",
      "enum": [
        "approve_pr",
        "request_changes",
        "run_workflow",
        "defer"
      ]
    },
    "decision_scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_quality",
        "rollback_readiness",
        "blast_radius",
        "confidence"
      ],
      "properties": {
        "evidence_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "rollback_readiness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "blast_radius": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "rollback_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "command",
        "verification"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "claim_classes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_docs",
        "runtime_validation",
        "autonomy_eligibility"
      ],
      "properties": {
        "governance_docs": {
          "type": "string",
          "enum": [
            "accepted",
            "pending"
          ]
        },
        "runtime_validation": {
          "type": "string",
          "enum": [
            "not_claimed",
            "validated"
          ]
        },
        "autonomy_eligibility": {
          "type": "string",
          "enum": [
            "not_claimed",
            "eligible"
          ]
        }
      }
    },
    "component_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_ready_payload_present",
        "deploy_ready",
        "tested_on_target",
        "rollback_verified",
        "runtime_validated",
        "autonomy_eligible",
        "tested_scope",
        "evidence_path",
        "rollback_path",
        "source_ref"
      ],
      "properties": {
        "repo_ready_payload_present": {
          "type": "boolean"
        },
        "deploy_ready": {
          "type": "boolean"
        },
        "tested_on_target": {
          "type": "boolean"
        },
        "rollback_verified": {
          "type": "boolean"
        },
        "runtime_validated": {
          "type": "boolean"
        },
        "autonomy_eligible": {
          "type": "boolean"
        },
        "tested_scope": {
          "type": "string",
          "minLength": 1
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "rollback_path": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_path",
        "tested_scope",
        "source_ref",
        "rollback_verification"
      ],
      "properties": {
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "tested_scope": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rollback_verification": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "autonomy_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_path",
        "tested_scope",
        "source_ref",
        "rollback_path"
      ],
      "properties": {
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "tested_scope": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rollback_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "claim_classes": {
            "properties": {
              "runtime_validation": {
                "const": "validated"
              }
            },
            "required": [
              "runtime_validation"
            ]
          }
        }
      },
      "then": {
        "required": [
          "runtime_claim"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "claim_classes": {
            "properties": {
              "autonomy_eligibility": {
                "const": "eligible"
              }
            },
            "required": [
              "autonomy_eligibility"
            ]
          }
        }
      },
      "then": {
        "required": [
          "autonomy_claim"
        ]
      }
    }
  ]
}
